# ── 오늘의 바다 backend 환경변수 예시 ──
# 실제 값은 .env 로 복사해서 채우세요 (.env 는 gitignore 됨)

# 데이터 provider: auto(추천)=키 있으면 hybrid(KHOA 실측+예보 백필), 없으면 openmeteo
#   선택지: auto | openmeteo(키리스) | khoa(순수 실측) | hybrid(실측+예보 백필)
# Open-Meteo 는 키 없이 즉시 동작 → 아래 인증키 없어도 라이브 데이터 서빙됨
DATA_PROVIDER=auto

# 공공데이터포털 인증키 (Phase 2 업그레이드용 — 없어도 Open-Meteo 로 동작)
# KHOA: 데이터 ID 15155516, 해양관측부이 최신 관측데이터
#   https://www.data.go.kr/data/15155516/openapi.do
#   https://apis.data.go.kr/1192136/twRecent/GetTWRecentApiService
# KHOA 조위: 데이터 ID 15155508, 조위관측소 최신 관측데이터
#   https://www.data.go.kr/data/15155508/openapi.do
#   https://apis.data.go.kr/1192136/dtRecent/GetDTRecentApiService
#   KHOA_TIDE_API_KEY가 비어 있으면 KHOA_API_KEY를 재사용함.
# KMA: 데이터 ID 15000415, 기상특보 조회서비스 (특보 전용; wind_speed 없음)
#   https://www.data.go.kr/data/15000415/openapi.do
#   https://apis.data.go.kr/1360000/WthrWrnInfoService/getPwnStatus
# 신규 URL·방어 파서·부산권 KHOA 부이 코드는 반영됨. 키 입력 후 아래 명령으로
# 실제 응답/단위를 검증하고 snapshot.json을 갱신해야 함:
#   cd backend && python -m app.ingest.collect
# KMA getPwnStatus는 현재 응답 전체에서 "부산"이 명시된 특보만 보수적으로 채택함.
# 실제 키 응답으로 공식 해역 필드와 해제 표현을 검증해야 함.
KHOA_API_KEY=
KHOA_TIDE_API_KEY=
KMA_API_KEY=

# Claude API (briefing LLM) — 없으면 템플릿 전용으로 폴백
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# 데모/운영 플래그
USE_SNAPSHOT_ONLY=1     # API는 스냅샷을 서빙; 라이브 갱신은 위 collect 명령/Actions가 수행
FORCE_MISSING=0         # 1 이면 임계 지표를 강제 결측 처리(자백 경로 드릴)

# CORS (frontend origin). 운영·미리보기 주소를 함께 허용해야 하면 쉼표로 구분합니다.
# 예: FRONTEND_ORIGIN=https://oneul-ui-bada.vercel.app,https://oneul-ui-bada-preview.vercel.app
FRONTEND_ORIGIN=http://localhost:5173
